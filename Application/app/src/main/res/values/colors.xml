<resources>
    <!-- =============================================
         Palette NexusCare – Contrôle Parental
         Indigo profond + Vert émeraude
    ============================================= -->

    <!-- Primaire -->
    <color name="colorPrimary">#1A237E</color>          <!-- Indigo profond -->
    <color name="colorPrimaryDark">#0D1757</color>      <!-- Status bar, variante sombre -->
    <color name="colorPrimaryVariant">#283593</color>   <!-- Variante plus claire pour surfaces -->

    <!-- Accent -->
    <color name="colorAccent">#00BFA5</color>           <!-- Vert émeraude -->
    <color name="colorAccentDark">#008E76</color>       <!-- Vert foncé pour accessibilité texte -->

    <!-- Arrière-plans clairs -->
    <color name="colorBackground">#F5F7FA</color>        <!-- Fond général clair -->
    <color name="colorSurface">#FFFFFF</color>           <!-- Cartes, dialogues -->
    <color name="colorOnPrimary">#FFFFFF</color>         <!-- Texte sur fond primaire -->
    <color name="colorOnBackground">#1C1B1F</color>      <!-- Texte principal sur fond clair -->
    <color name="colorOnSurface">#1C1B1F</color>         <!-- Texte sur surfaces claires -->

    <!-- Erreur / Alerte -->
    <color name="colorError">#D32F2F</color>             <!-- Rouge matériel -->
    <color name="colorOnError">#FFFFFF</color>           <!-- Texte sur erreur -->

    <!-- Couleurs fonctionnelles -->
    <color name="colorSuccess">#2E7D32</color>           <!-- Vert succès -->
    <color name="colorWarning">#F57F17</color>           <!-- Orange avertissement -->
    <color name="colorDisabled">#9E9E9E</color>          <!-- Désactivé -->

